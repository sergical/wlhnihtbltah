# Copy to apps/worker/.dev.vars for local dev, or set via `wrangler secret put` for prod.

# Required
ANTHROPIC_API_KEY=sk-ant-...
MUX_TOKEN_ID=...              # new token with Mux Robots scope
MUX_TOKEN_SECRET=...
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...
JAZZ_API_KEY=...              # project id from dashboard.jazz.tools
PUBLIC_APP_URL=https://<your-subdomain>.workers.dev

# Optional — Cloudflare AI Gateway for observability/caching/failover.
# Set AI_GATEWAY_ID empty string to bypass the gateway.
AI_GATEWAY_ID=default
CF_ACCOUNT_ID=<your-cf-account-id>
CF_AIG_TOKEN=<cf-user-api-token-with-ai-gateway-access>
